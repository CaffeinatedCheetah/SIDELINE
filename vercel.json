{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; frame-src https://www.youtube.com https://www.dailymotion.com; connect-src 'self' https:; object-src 'none'; base-uri 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "crons": [
    { "path": "/api/agent-social",   "schedule": "*/15 * * * *" },
    { "path": "/api/agent-breaking", "schedule": "*/5 * * * *"  },
    { "path": "/api/agent-hunter",   "schedule": "*/5 * * * *"  },
    { "path": "/api/agent-worldcup", "schedule": "*/5 * * * *"  },
    { "path": "/api/agent-pulse",    "schedule": "*/30 * * * *" },
    { "path": "/api/agent-rivals",   "schedule": "0 * * * *"    }
  ]
}
